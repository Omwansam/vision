PORT=5000
NODE_ENV=development

# Comma-separated browser origins (ngo dev :5173, admin dev :5174)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Local Postgres (docker-compose uses port 5433 on host)
DATABASE_URL=postgresql://dan:YOUR_PASSWORD@localhost:5433/vision

WEBSITE_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# SMTP (optional in development)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_FROM_NAME=Vision Mentors Group
# ADMIN_NOTIFICATION_EMAIL=info@visionmentors.org
