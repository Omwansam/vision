# Copy to .env on the server:
#   cp .env.example .env
#
# .env is gitignored — never commit it.

# ─── PostgreSQL (REQUIRED) ───────────────────────────────────────────────────
POSTGRES_USER=dan
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_48
POSTGRES_DB=vision

# ─── Backend auth (REQUIRED) ───────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48
JWT_EXPIRES_IN=7d

# ─── Public URLs (REQUIRED for production) ─────────────────────────────────────
# Comma-separated origins for CORS — must match browser URLs exactly.
FRONTEND_URL=https://visionmentors.org,https://admin.visionmentors.org

# Baked into frontend Docker images at build time. Use a relative path so each
# site calls its own domain (/api/v1 → proxied to the backend by nginx).
VITE_API_URL=/api/v1

WEBSITE_URL=https://visionmentors.org
BACKEND_URL=https://visionmentors.org

# ─── Edge proxy ────────────────────────────────────────────────────────────────
HTTP_PORT=80

# ─── SMTP (required for email notifications in production) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Vision Mentors Group
ADMIN_NOTIFICATION_EMAIL=info@visionmentors.org

# ─── First deploy only (optional) ────────────────────────────────────────────
# Set to true once to copy gallery images and seed page image URLs after migrate.
# INIT_CONTENT=true
