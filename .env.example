# Copy to .env and fill in every value marked REQUIRED.
#   cp .env.example .env
#
# .env is gitignored — never commit it.

# PostgreSQL (REQUIRED)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=vision
POSTGRES_PORT=5432

# Backend auth (REQUIRED)
JWT_SECRET=
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Service ports (optional)
BACKEND_PORT=5000
NGO_WEBSITE_PORT=5173
ADMIN_PORT=5174

# Public API URL baked into frontend builds at build time (REQUIRED)
VITE_API_URL=http://localhost:5000/api/v1

# Public website URL (used in email content links)
WEBSITE_URL=http://localhost:5173

# Backend base URL (used in email unsubscribe links)
BACKEND_URL=http://localhost:5000

# SMTP email — nodemailer (optional in dev; required in production for notifications)
# Works with Gmail, SendGrid, Mailgun, Amazon SES, or any SMTP provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Vision Mentors Group

# Fallback inbox when site settings contact email is not set
ADMIN_NOTIFICATION_EMAIL=
