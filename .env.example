# Copy to .env and fill in every value marked REQUIRED.
#   cp .env.example .env
#
# .env is gitignored — never commit it.

# PostgreSQL (REQUIRED)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=vision
POSTGRES_PORT=5432

# Backend auth (REQUIRED)
JWT_SECRET=
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Service ports (optional)
BACKEND_PORT=5000
NGO_WEBSITE_PORT=5173
ADMIN_PORT=5174

# Public API URL baked into frontend builds at build time (REQUIRED)
VITE_API_URL=http://localhost:5000/api/v1
